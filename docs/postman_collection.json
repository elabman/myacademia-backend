{
  "info": {
    "name": "db_myacademia API",
    "description": "RP Kigali College - Short Courses & Partner/Donor Projects Registry API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Jane Uwase\",\n  \"email\": \"jane.uwase@rpkigali.rw\",\n  \"password\": \"Secret123\",\n  \"role_id\": 3,\n  \"department_id\": 5,\n  \"phone\": \"+250788123456\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.data) {",
                  "  pm.collectionVariables.set('accessToken', json.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rpkigali.rw\",\n  \"password\": \"YourPassword123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh-token",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Get Profile (me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/me",
            "body": { "mode": "raw", "raw": "{\n  \"full_name\": \"Jane Uwase Updated\",\n  \"phone\": \"+250788000000\"\n}" }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/auth/change-password",
            "body": { "mode": "raw", "raw": "{\n  \"currentPassword\": \"Secret123\",\n  \"newPassword\": \"NewSecret456\"\n}" }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"jane.uwase@rpkigali.rw\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<token-from-forgot-password>\",\n  \"newPassword\": \"NewSecret456\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Short Courses",
      "item": [
        {
          "name": "List (paginated/search/filter/sort)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/short-courses?page=1&limit=10&search=ICT&status=Completed&sort=course_title&order=asc",
              "host": ["{{baseUrl}}"],
              "path": ["short-courses"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "search", "value": "ICT" },
                { "key": "status", "value": "Completed" },
                { "key": "sort", "value": "course_title" },
                { "key": "order", "value": "asc" }
              ]
            }
          }
        },
        {
          "name": "Summary (dashboard)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/short-courses/summary"
          }
        },
        {
          "name": "Get by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/short-courses/1"
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/short-courses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"course_title\": \"Welding Fundamentals\",\n  \"department_id\": 3,\n  \"category_id\": 4,\n  \"duration_days\": 30,\n  \"duration_hours\": 240,\n  \"level\": \"Beginner\",\n  \"delivery_mode_id\": 1,\n  \"language\": \"English\",\n  \"participants_female\": 5,\n  \"participants_male\": 15,\n  \"total_certified\": 0,\n  \"fee_per_participant\": 50000,\n  \"status\": \"Planning\"\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/short-courses/1",
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"Active\",\n  \"total_certified\": 10\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/short-courses/1"
          }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects?page=1&limit=10"
          }
