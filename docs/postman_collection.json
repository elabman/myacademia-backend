        {
          "name": "Summary (dashboard)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/summary"
          }
        },
        {
          "name": "Get by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1"
          }
        },
        {
          "name": "Get Full (joined + departments + partners)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1/full"
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/projects",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"project_title\": \"Digital Skills for Rural Youth\",\n  \"donor_id\": 1,\n  \"funding_type_id\": 1,\n  \"sector_id\": 3,\n  \"start_date\": \"2026-09-01\",\n  \"end_date\": \"2027-08-31\",\n  \"total_budget_usd\": 50000,\n  \"overall_status\": \"Pipeline\"\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/projects/1",
            "body": { "mode": "raw", "raw": "{\n  \"overall_status\": \"Active\",\n  \"achievement_rate_pct\": 25.5\n}" }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1"
          }
        },
        {
          "name": "List Target Departments",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1/departments"
          }
        },
        {
          "name": "Link Department",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/projects/1/departments",
            "body": { "mode": "raw", "raw": "{\n  \"department_id\": 5\n}" }
          }
        },
        {
          "name": "Unlink Department",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1/departments/5"
          }
        },
        {
          "name": "List Partners",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1/partners"
          }
        },
        {
          "name": "Link Partner",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/projects/1/partners",
            "body": { "mode": "raw", "raw": "{\n  \"partner_id\": 1\n}" }
          }
        },
        {
          "name": "Unlink Partner",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/projects/1/partners/1"
          }
        }
      ]
    },
    {
      "name": "Lookup Tables",
      "item": [
        {
          "name": "Departments - List",
          "request": {
            "method": "GET",
