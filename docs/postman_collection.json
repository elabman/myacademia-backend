            ],
            "url": "{{baseUrl}}/departments/1",
            "body": { "mode": "raw", "raw": "{\n  \"department_name\": \"Automobile Technology (Updated)\"\n}" }
          }
        },
        {
          "name": "Departments - Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/departments/9"
          }
        },
        {
          "name": "Donors - List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/donors"
          }
        },
        {
          "name": "Sectors - List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/sectors"
          }
        },
        {
          "name": "Academic Years - List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/academic-years"
          }
        }
      ]
    },
    {
      "name": "Users & Staff",
      "item": [
        {
          "name": "Users - List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users?page=1&limit=10"
          }
        },
        {
          "name": "Users - Get by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/users/1"
          }
        },
        {
          "name": "Users - Update",
          "request": {
            "method": "PUT",
