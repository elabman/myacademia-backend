    {
      "name": "Approvals & Audit Log",
      "item": [
        {
          "name": "Approvals - List Pending",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/approvals?decision=Pending"
          }
        },
        {
          "name": "Approvals - Create Request",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/approvals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entity_type\": \"short_course\",\n  \"entity_id\": 1,\n  \"requested_by\": 3,\n  \"role_required\": 1\n}"
            }
          }
        },
        {
          "name": "Approvals - Record Decision",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{baseUrl}}/approvals/1",
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"Approved\",\n  \"reviewer_id\": 1,\n  \"comments\": \"Looks good\"\n}" }
          }
        },
        {
          "name": "Audit Log - List",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/audit-log?table_name=short_courses"
          }
        }
